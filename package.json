{
  "name": "sovereign-genesis",
  "version": "1.0.0",
  "description": "SOVEREIGN-GENESIS: Self-evolving autonomous AI agent on Tezos Etherlink",
  "private": true,
  "scripts": {
    "compile":       "hardhat compile",
    "test":          "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network etherlink_testnet",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network etherlink_mainnet",
    "agent":         "node agent/index.js",
    "webhook":       "node webhook/server.js"
  },
  "dependencies": {
    "@openzeppelin/contracts":              "^5.0.2",
    "@octokit/rest":                        "^20.1.1",
    "dotenv":                               "^16.4.5",
    "ethers":                               "^6.11.1",
    "express":                              "^4.18.2",
    "body-parser":                          "^1.20.2",
    "openai":                               "^4.38.5",
    "node-fetch":                           "^3.3.2",
    "winston":                              "^3.13.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox":     "^5.0.0",
    "hardhat":                              "^2.22.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
