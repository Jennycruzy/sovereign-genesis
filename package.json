{
  "name": "sovereign-genesis",
  "version": "1.0.0",
  "description": "A financially sovereign, self-evolving AI agent on Tezos Etherlink",
  "main": "agent/index.js",
  "scripts": {
    "start": "node agent/index.js",
    "webhook": "node webhook/server.js",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network etherlink",
    "test": "jest",
    "test:contract": "npx hardhat test",
    "lint": "eslint agent/ webhook/ scripts/ --ext .js",
    "lint:fix": "eslint agent/ webhook/ scripts/ --ext .js --fix"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "ethers": "^6.8.0",
    "express": "^4.18.2",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "openai": "^4.20.1"
  },
  "devDependencies": {
    "hardhat": "^2.19.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "jest": "^29.7.0",
    "eslint": "^8.55.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "testMatch": [
      "**/test/**/*.test.js",
      "**/agent/**/*.test.js"
    ]
  },
  "keywords": [
    "ai",
    "blockchain",
    "tezos",
    "etherlink",
    "autonomous",
    "bounty"
  ],
  "author": "SOVEREIGN-GENESIS",
  "license": "MIT"
}