# ═══════════════════════════════════════════════════════════════════════════════
# SOVEREIGN-GENESIS — Environment Configuration
# Copy this file to .env and fill in all values before running.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Blockchain ─────────────────────────────────────────────────────────────────

# Etherlink Ghostnet (testnet) RPC
ETHERLINK_RPC=https://node.ghostnet.etherlink.com

# Etherlink Mainnet RPC
ETHERLINK_MAINNET=https://node.mainnet.etherlink.com

# Deployer private key (used by Hardhat deploy script)
# !! NEVER commit this value !!
DEPLOYER_PRIVATE_KEY=0x...

# Agent private key (used by the Node.js evolution engine)
# This is the account set as `agent` in the contract
AGENT_PRIVATE_KEY=0x...

# Agent wallet address (set during deployment)
AGENT_ADDRESS=0x...

# Optional: initial XTZ to send to the contract treasury after deploy
SEED_XTZ=2

# Life-support buffer in XTZ (minimum treasury balance)
LIFE_SUPPORT_BUFFER_XTZ=1

# ── GitHub ─────────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (needs repo + pull_request scopes)
GITHUB_TOKEN=ghp_...

# Repository to watch in "owner/repo" format
GITHUB_REPO=your-org/your-repo

# Webhook secret (set in GitHub repo settings → Webhooks)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── AI Judge ──────────────────────────────────────────────────────────────────

# OpenAI (or compatible) API key
OPENAI_API_KEY=sk-...

# Model to use for code review (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ── Agent tuning ──────────────────────────────────────────────────────────────

# Smart Issue Poller Configuration
# Base interval for GitHub issue polling (ms)
SCAN_INTERVAL_MS=60000

# Maximum interval after consecutive failures (ms)
SCAN_MAX_INTERVAL_MS=300000

# Minimum interval after consecutive successes (ms)
SCAN_MIN_INTERVAL_MS=30000

# Enable exponential backoff on failures (true/false)
SCAN_ENABLE_BACKOFF=true

# Backoff multiplier for interval adjustment (1.5 = 50% increase/decrease)
SCAN_BACKOFF_MULTIPLIER=1.5

# Number of consecutive failures before resetting to base interval
SCAN_FAILURE_THRESHOLD=3

# How often to run financial awareness loop (ms)
FINANCIAL_INTERVAL_MS=300000

# Fraction of spendable balance that triggers surplus investment (0–1)
INVEST_THRESHOLD_RATIO=0.5

# DeFi yield target address on Etherlink (optional)
# If empty, investSurplus() is never called automatically
YIELD_TARGET_ADDRESS=

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ── Dashboard ─────────────────────────────────────────────────────────────────

# These are NEXT_PUBLIC_ so they are exposed to the browser
NEXT_PUBLIC_ETHERLINK_RPC=https://node.ghostnet.etherlink.com
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_POLL_INTERVAL_MS=5000

# ── Webhook server ────────────────────────────────────────────────────────────

WEBHOOK_PORT=3001

# ── Block explorer API key (optional, for contract verification) ──────────────
EXPLORER_API_KEY=
